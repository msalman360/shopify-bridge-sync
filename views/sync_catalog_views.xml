<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- SEARCH VIEW (Pehle define karein) -->
    <record id="view_sync_catalog_search" model="ir.ui.view">
        <field name="name">sync.catalog.search</field>
        <field name="model">sync.catalog</field>
        <field name="arch" type="xml">
            <search string="Products">
                <field name="name"/>
                <field name="sku"/>
                <field name="remote_id"/>
                <field name="shopify_product_id"/>
                <field name="vendor"/>
                <field name="product_type"/>
                <field name="tags"/>
                <separator/>
                <filter string="Synced" name="synced" domain="[('sync_state', '=', 'synced')]"/>
                <filter string="Pending" name="pending" domain="[('sync_state', '=', 'pending')]"/>
                <filter string="Error" name="error" domain="[('sync_state', '=', 'error')]"/>
                <separator/>
                <filter string="Active" name="active_status" domain="[('status', '=', 'active')]"/>
                <filter string="Draft" name="draft_status" domain="[('status', '=', 'draft')]"/>
                <filter string="Archived" name="archived_status" domain="[('status', '=', 'archived')]"/>
                <group expand="0" string="Group By">
                    <filter string="Store" name="group_store" context="{'group_by': 'store_id'}"/>
                    <filter string="Sync State" name="group_state" context="{'group_by': 'sync_state'}"/>
                    <filter string="Product Type" name="group_type" context="{'group_by': 'product_type'}"/>
                    <filter string="Vendor" name="group_vendor" context="{'group_by': 'vendor'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_sync_catalog" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">sync.catalog</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_sync_catalog_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No products synced yet.</p>
            <p>Sync products from your Shopify store to get started.</p>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_sync_catalog_kanban" model="ir.ui.view">
        <field name="name">sync.catalog.kanban</field>
        <field name="model">sync.catalog</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="image"/>
                <field name="price"/>
                <field name="sync_state"/>
                <field name="store_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('sync.catalog', 'image', record.id.raw_value)" alt="Product"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="o_kanban_tags_section">
                                    <span class="badge badge-pill" t-attf-class="badge {{ record.sync_state.raw_value == 'synced' ? 'badge-success' : (record.sync_state.raw_value == 'error' ? 'badge-danger' : 'badge-warning') }}">
                                        <field name="sync_state"/>
                                    </span>
                                    <span t-if="record.auto_sync_enabled.raw_value" class="badge badge-primary">Auto</span>
                                </div>
                                <div><field name="store_id"/> • $<field name="price"/></div>
                                <div>SKU: <field name="sku"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_sync_catalog_list" model="ir.ui.view">
        <field name="name">sync.catalog.list</field>
        <field name="model">sync.catalog</field>
        <field name="arch" type="xml">
            <list string="Products" decoration-muted="sync_state == 'pending'" decoration-danger="sync_state == 'error'" decoration-success="sync_state == 'synced'">
                <field name="image_small" widget="image" options="{'size': [40, 40]}" optional="show"/>
                <field name="name" string="Title"/>
                <field name="store_id"/>
                <field name="sku" optional="show"/>
                <field name="price" optional="show"/>
                <field name="inventory_quantity" optional="show"/>
                <field name="product_type" optional="hide"/>
                <field name="vendor" optional="hide"/>
                <field name="sync_state" widget="badge" decoration-success="sync_state == 'synced'" decoration-warning="sync_state == 'pending'" decoration-danger="sync_state == 'error'"/>
                <field name="auto_sync_enabled" widget="boolean_toggle" optional="show"/>
                <field name="last_synced" optional="show"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_sync_catalog_form" model="ir.ui.view">
        <field name="name">sync.catalog.form</field>
        <field name="model">sync.catalog</field>
        <field name="arch" type="xml">
            <form string="Product">
                <header>
                    <button name="action_sync_from_shopify" type="object" string="Sync from Shopify" class="oe_highlight" icon="fa-refresh"/>
                    <button name="action_sync_to_shopify" type="object" string="Sync to Shopify" icon="fa-upload"/>
                    <button name="action_view_in_shopify" type="object" string="View in Shopify" icon="fa-external-link"/>
                    <field name="sync_state" widget="statusbar" statusbar_visible="pending,synced,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Product Title"/></h1>
                    </div>
                    <div class="oe_left">
                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image_medium', 'size': [180, 180]}"/>
                    </div>
                    <group>
                        <group string="Basic Information">
                            <field name="store_id" options="{'no_create': True}"/>
                            <field name="remote_id" readonly="1"/>
                            <field name="shopify_product_id"/>
                            <field name="product_type"/>
                            <field name="vendor"/>
                            <field name="tags" placeholder="tag1, tag2, tag3"/>
                            <field name="status" widget="radio"/>
                        </group>
                        <group string="Pricing">
                            <field name="price"/>
                            <field name="compare_at_price"/>
                            <field name="cost_price"/>
                            <field name="currency"/>
                        </group>
                    </group>
                    <group>
                        <group string="Inventory">
                            <field name="sku"/>
                            <field name="barcode"/>
                            <field name="inventory_quantity"/>
                            <field name="inventory_policy" widget="radio"/>
                            <field name="fulfillment_service"/>
                            <field name="weight"/>
                            <field name="weight_unit"/>
                        </group>
                        <group string="Sync Settings">
                            <field name="auto_sync_enabled" widget="boolean_toggle"/>
                            <field name="sync_state"/>
                            <field name="last_synced" readonly="1"/>
                            <field name="last_error"/>
                            <field name="sync_direction"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html" options="{'style-inline': true}" placeholder="Enter product description..."/>
                        </page>
                        <page string="Variants">
                            <field name="variant_ids" mode="list">
                                <list editable="bottom">
                                    <field name="image" widget="image" options="{'size': [30, 30]}" optional="show"/>
                                    <field name="name"/>
                                    <field name="sku"/>
                                    <field name="price"/>
                                    <field name="compare_at_price"/>
                                    <field name="inventory_quantity"/>
                                    <field name="barcode"/>
                                    <field name="sync_state" widget="badge"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="sku"/>
                                            <field name="price"/>
                                            <field name="inventory_quantity"/>
                                            <field name="barcode"/>
                                            <field name="weight"/>
                                            <field name="weight_unit"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Images">
                            <field name="image_ids" mode="kanban">
                                <kanban>
                                    <field name="src"/>
                                    <field name="position"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_click">
                                                <img t-att-src="record.src.raw_value" style="max-width: 150px; max-height: 150px;"/>
                                                <div>Pos: <field name="position"/></div>
                                                <div><field name="alt"/></div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="SEO">
                            <group>
                                <field name="seo_title" placeholder="SEO optimized title..."/>
                                <field name="seo_description" placeholder="Meta description..."/>
                                <field name="handle" placeholder="url-friendly-handle"/>
                                <field name="slug"/>
                            </group>
                        </page>
                        <page string="Raw Data">
                            <field name="raw_data" widget="ace" options="{'mode': 'json'}" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
